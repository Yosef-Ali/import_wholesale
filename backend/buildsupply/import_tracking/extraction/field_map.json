{
  "_comment": "Declarative map of which source document yields which cost-sheet field. Used to drive OCR/data-entry templates. Fill `anchors` with the exact label text once the real scans arrive; `target` is the Import Shipment fieldname (or charges[].description for a ledger line).",
  "documents": [
    {
      "doc_type": "commercial_invoice",
      "label": "Commercial Invoice",
      "primary": true,
      "header_fields": [
        {"target": "commercial_invoice_no", "anchors": ["Invoice No", "Invoice #"]},
        {"target": "supplier", "anchors": ["Seller", "Exporter", "Shipper"]},
        {"target": "invoice_value_fcy", "anchors": ["Total", "Total Amount", "FOB Total"]},
        {"target": "origin_country", "anchors": ["Country of Origin", "Origin"]}
      ],
      "line_items": {
        "target_table": "item_allocation",
        "columns": {
          "description": ["Description", "Goods", "Commodity"],
          "qty": ["Qty", "Quantity", "PCS"],
          "fob_unit_price": ["Unit Price", "Price", "U/Price"]
        },
        "note": "weight_basis = qty * fob_unit_price; this drives the landed-cost allocation"
      },
      "charge_line": {"description": "Invoice Price (FOB)", "is_fob": true, "charge_group": "Cost Basis"}
    },
    {
      "doc_type": "packing_list",
      "label": "Packing List",
      "line_items": {
        "target_table": "item_allocation",
        "columns": {"description": ["Description"], "qty": ["Qty", "Pcs", "Quantity"]},
        "note": "use to cross-check qty against the commercial invoice"
      }
    },
    {
      "doc_type": "customs_declaration",
      "label": "Customs Declaration / DVP sheet",
      "header_fields": [
        {"target": "declaration_number", "anchors": ["Declaration No", "Decl No"]},
        {"target": "tin_number", "anchors": ["TIN"]},
        {"target": "tax_payer", "anchors": ["Tax Payer", "Importer"]},
        {"target": "dvp_value", "anchors": ["DVP", "Customs Value", "Assessed Value"]}
      ],
      "charge_lines": [
        {"description": "Customs Duty Tax (15%/35%)", "charge_group": "Duty & Tax", "anchors": ["Duty", "Customs Duty"]},
        {"description": "Sur tax", "charge_group": "Duty & Tax", "anchors": ["Surtax", "Sur Tax"]},
        {"description": "Social Welfare Tax (3%)", "charge_group": "Duty & Tax", "anchors": ["Social Welfare", "Welfare"]},
        {"description": "Scanning Fee (7%)", "charge_group": "Duty & Tax", "anchors": ["Scanning"]},
        {"description": "Vat Receivable", "charge_group": "Duty & Tax", "anchors": ["VAT"]},
        {"description": "Withholding On Customs", "charge_group": "Duty & Tax", "anchors": ["Withholding", "WHT"]}
      ]
    },
    {
      "doc_type": "freight_invoice",
      "label": "Freight Invoice",
      "header_fields": [{"target": "bl_number", "anchors": ["B/L", "BL No", "Bill of Lading"]}],
      "charge_lines": [
        {"description": "Sea Freight Charge", "charge_group": "Cost Basis", "anchors": ["Ocean Freight", "Sea Freight", "Freight"]}
      ]
    },
    {
      "doc_type": "clearing_agent_invoice",
      "label": "Clearing / Transitor Agent Invoice",
      "charge_lines": [
        {"description": "Port Clearance charges (Djibouti)", "charge_group": "Cost Basis", "anchors": ["Port Clearance", "Djibouti"]},
        {"description": "Transportation Cost From Djibouti to Modjo", "charge_group": "Freight & Logistics", "anchors": ["Djibouti to Modjo", "Transport"]},
        {"description": "ESLSE Modjo Port/Terminal service", "charge_group": "Handling", "anchors": ["ESLSE", "Terminal"]},
        {"description": "Transit Cost", "charge_group": "Freight & Logistics", "anchors": ["Transit"]},
        {"description": "Container Unstuffing", "charge_group": "Handling", "anchors": ["Unstuffing", "Stripping"]},
        {"description": "Transportation Cost From Modjo to warehouse", "charge_group": "Freight & Logistics", "anchors": ["Modjo to warehouse", "Delivery"]},
        {"description": "Demurrage", "charge_group": "Handling", "anchors": ["Demurrage", "Detention"]}
      ]
    },
    {
      "doc_type": "bank_advice",
      "label": "Bank Permit & Charge Advice",
      "header_fields": [
        {"target": "bank_permit_number", "anchors": ["Permit No", "Permit"]},
        {"target": "fcy_rate", "anchors": ["Rate", "Exchange Rate", "FX"]}
      ],
      "charge_lines": [
        {"description": "Service Charge On Opening CAD", "charge_group": "Bank", "anchors": ["CAD", "Opening", "L/C"]},
        {"description": "Postage/Swift charges/exchange", "charge_group": "Bank", "anchors": ["Swift", "Postage", "Telex"]},
        {"description": "Bank Service Charge on Freight & Port", "charge_group": "Bank", "anchors": ["Service Charge"]},
        {"description": "Bank CPO charges", "charge_group": "Bank", "anchors": ["CPO"]}
      ]
    },
    {
      "doc_type": "insurance_certificate",
      "label": "Insurance Certificate",
      "charge_lines": [
        {"description": "Insurance", "charge_group": "Cost Basis", "anchors": ["Premium", "Insurance"]}
      ]
    }
  ]
}
